#!/usr/bin/env bash
set -euo pipefail

SKILLS_DIR="$HOME/.claude/skills"
REPO_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ $# -eq 0 ]; then
  echo "Uninstalling all skills from this repo..."
  for dir in "$REPO_DIR"/*/; do
    name="$(basename "$dir")"
    [ "$name" = "bin" ] && continue
    dst="$SKILLS_DIR/$name"
    if [ -L "$dst" ] && [ "$(readlink "$dst")" = "$REPO_DIR/$name" ]; then
      rm "$dst"
      echo "Removed $name"
    fi
  done
  for f in "$REPO_DIR"/*.md; do
    [ -f "$f" ] || continue
    name="$(basename "$f" .md)"
    [ "$name" = "README" ] && continue
    dst="$SKILLS_DIR/$name"
    if [ -L "$dst" ] && [ "$(readlink "$dst")" = "$REPO_DIR/$f" ]; then
      rm "$dst"
      echo "Removed $name"
    fi
  done
else
  for name in "$@"; do
    dst="$SKILLS_DIR/$name"
    src="$REPO_DIR/$name"
    if [ -L "$dst" ] && [ "$(readlink "$dst")" = "$src" ]; then
      rm "$dst"
      echo "Removed $name"
    else
      echo "Warning: $name is not installed from this repo, skipping" >&2
    fi
  done
fi

echo ""
echo "Done."
