#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"

target_dir() {
  case "$1" in
    claude) echo "$HOME/.claude/skills" ;;
    hermes) echo "$HOME/.hermes/skills" ;;
    cursor) echo "$HOME/.cursor/skills" ;;
  esac
}

ACTIVE_TARGETS=()
ARGS=()
for arg in "$@"; do
  case "$arg" in
    --claude|--hermes|--cursor) ACTIVE_TARGETS+=("${arg#--}") ;;
    *) ARGS+=("$arg") ;;
  esac
done

if [ ${#ACTIVE_TARGETS[@]} -eq 0 ]; then
  ACTIVE_TARGETS=(claude hermes cursor)
fi

uninstall_skill() {
  local name="$1" dst="$2"
  local marker="$dst/.installed-from"

  if [ ! -e "$dst" ]; then
    echo "  Warning: $name is not installed, skipping" >&2
    return
  fi

  if [ -f "$marker" ] && [ "$(cat "$marker")" = "$REPO_DIR" ]; then
    rm -rf "$dst"
    echo "  Removed $name"
  else
    echo "  Warning: $name was not installed from this repo, skipping" >&2
  fi
}

for target in "${ACTIVE_TARGETS[@]}"; do
  skills_dir="$(target_dir "$target")"
  echo "Uninstalling from $skills_dir ..."

  if [ ${#ARGS[@]} -eq 0 ]; then
    for dir in "$skills_dir"/*/; do
      [ -d "$dir" ] || continue
      name="$(basename "$dir")"
      uninstall_skill "$name" "$dir"
    done
  else
    for name in "${ARGS[@]}"; do
      uninstall_skill "$name" "$skills_dir/$name"
    done
  fi
done

echo ""
echo "Done."
