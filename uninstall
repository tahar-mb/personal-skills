#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$HOME/.claude/skills"

uninstall_skill() {
  local name="$1"
  local dst="$SKILLS_DIR/$name"
  local marker="$dst/.installed-from"

  if [ ! -e "$dst" ]; then
    echo "Warning: $name is not installed, skipping" >&2
    return
  fi

  if [ -f "$marker" ] && [ "$(cat "$marker")" = "$REPO_DIR" ]; then
    rm -rf "$dst"
    echo "Removed $name"
  else
    echo "Warning: $name was not installed from this repo, skipping" >&2
  fi
}

if [ $# -eq 0 ]; then
  echo "Uninstalling all skills installed from this repo..."
  for dir in "$SKILLS_DIR"/*/; do
    [ -d "$dir" ] || continue
    name="$(basename "$dir")"
    uninstall_skill "$name"
  done
else
  for name in "$@"; do
    uninstall_skill "$name"
  done
fi

echo ""
echo "Done."
