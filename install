#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_SOURCES=("$REPO_DIR/skills" "$REPO_DIR")

target_dir() {
  case "$1" in
    claude) echo "$HOME/.claude/skills" ;;
    hermes) echo "$HOME/.hermes/skills" ;;
    cursor) echo "$HOME/.cursor/skills" ;;
  esac
}

ACTIVE_TARGETS=()

usage() {
  echo "Usage: ./install [--claude] [--hermes] [--cursor] [<skill-name> ...]"
  echo ""
  echo "Flags:"
  echo "  --claude   Install to ~/.claude/skills/   (default: all)"
  echo "  --hermes   Install to ~/.hermes/skills/  (default: all)"
  echo "  --cursor   Install to ~/.cursor/skills/  (default: all)"
  echo ""
  echo "If no flag is given, installs to all targets."
  echo "If skill names are given, only those skills are installed."
  exit 0
}

SKIP_FLAGS=false
ARGS=()
for arg in "$@"; do
  $SKIP_FLAGS && ARGS+=("$arg") && continue
  case "$arg" in
    --help|-h) usage ;;
    --claude|--hermes|--cursor)
      ACTIVE_TARGETS+=("${arg#--}")
      ;;
    --) SKIP_FLAGS=true ;;
    *) ARGS+=("$arg") ;;
  esac
done

if [ ${#ACTIVE_TARGETS[@]} -eq 0 ]; then
  ACTIVE_TARGETS=(claude hermes cursor)
fi

install_skill_to() {
  local name="$1" src="$2" dst="$3" label="$4"
  mkdir -p "$(dirname "$dst")"
  if [ -e "$dst" ] && [ ! -f "$dst/.installed-from" ]; then
    echo "  [$label] Warning: $dst already exists, skipping" >&2
    return 0
  fi
  rm -rf "$dst"
  cp -R "$src" "$dst"
  echo "$REPO_DIR" > "$dst/.installed-from"
  echo "  [$label] Installed $name"
}

find_skill_src() {
  local name="$1"
  if [ -d "$REPO_DIR/skills/$name" ]; then
    echo "$REPO_DIR/skills/$name"
  elif [ -d "$REPO_DIR/$name" ]; then
    echo "$REPO_DIR/$name"
  fi
}

install_to_target() {
  local target="$1"
  local dest="$(target_dir "$target")"
  echo "  Target: $dest"

  if [ ${#ARGS[@]} -eq 0 ]; then
    for base in "${SKILL_SOURCES[@]}"; do
      [ -d "$base" ] || continue
      for dir in "$base"/*/; do
        [ -d "$dir" ] || continue
        name="$(basename "$dir")"
        case "$name" in
          .git|.claude-plugin) continue ;;
        esac
        if [ -f "$dir/SKILL.md" ]; then
          install_skill_to "$name" "$dir" "$dest/$name" "$target"
        fi
      done
    done
  else
    for name in "${ARGS[@]}"; do
      src="$(find_skill_src "$name")"
      if [ -z "$src" ]; then
        echo "  [$target] Error: skill '$name' not found" >&2
        continue
      fi
      install_skill_to "$name" "$src" "$dest/$name" "$target"
    done
  fi
}

echo "Installing skills..."
for target in "${ACTIVE_TARGETS[@]}"; do
  install_to_target "$target"
done

echo ""
echo "Done. Restart your editor to use the skills."
